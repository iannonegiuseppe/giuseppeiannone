# Sanity project connection (public — exposed to the browser for the
# embedded Studio and client-side reads).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Server-only token with at least read access. Used for authenticated
# reads (e.g. draft content) and API routes; never exposed to the browser.
SANITY_API_READ_TOKEN=

# Shared secret checked by src/app/api/revalidate/route.ts (added in
# Step 8) against the Sanity webhook's configured secret.
SANITY_REVALIDATE_SECRET=

# The real production domain (e.g. https://giuseppeiannone.it), no trailing
# slash. Single source of truth for canonicals/hreflang/sitemap/JSON-LD URLs
# — leave unset until launch. Only indexable when this AND a Vercel
# production deployment (VERCEL_ENV=production, set automatically by
# Vercel) are both true; local dev and preview deployments are always
# noindex regardless. Any *.vercel.app host is ALSO always noindex as a
# separate hard rule (src/proxy.ts), even on the production deployment.
NEXT_PUBLIC_SITE_URL=

# TEMPORARY, write-scoped token used only by `npm run seed`
# (scripts/seed.ts). Create a token with "Editor" (write) permission in
# the Sanity project dashboard right before running the seed script, and
# delete it again immediately after — do not leave a write-capable token
# sitting in .env.local long-term.
SANITY_API_WRITE_TOKEN=

# Server-only, Viewer-scoped token dedicated to draft mode (Stage 2 Step
# 7) — lets src/app/api/draft-mode/enable read unpublished content once
# a Studio-signed preview request validates. Unlike SANITY_API_WRITE_TOKEN
# this is a long-lived credential (draft mode is an ongoing feature, not
# a one-off script), but keep it Viewer-only — it should never be able to
# write.
SANITY_API_PREVIEW_TOKEN=
