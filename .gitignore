# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Windows reserved device name — created accidentally when a command meant
# for cmd.exe's null-device redirect (e.g. `> nul`, `2>nul`) runs under
# Git Bash/MSYS instead, which doesn't special-case "nul" and just creates
# a literal file. Git can't index it (short read on the reserved name), so
# it's ignored here as a safety net rather than relied on to never recur.
/nul

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local review screenshots (visual QA during a stage, never committed)
/.review/

# reference/inspiration images (third-party template screenshots) — kept
# locally for design reference only, never committed
docs/**/*.webp
docs/**/*.jpg
docs/**/*.jpeg
docs/**/*.png
